# =============================================================================
# Security Scanning Platform — Environment Configuration
# =============================================================================
# Copy to .env and customise before starting the platform.
#
# IMPORTANT: Change ALL credentials before deploying to production.
# Generate secrets with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Generate bcrypt hash: python -c "import bcrypt; print(bcrypt.hashpw(b'YOURPASSWORD', bcrypt.gensalt()).decode())"
# =============================================================================

# --- Dashboard ---
DASHBOARD_PORT=8080
DASHBOARD_USERNAME=admin
# Use a bcrypt hash (recommended) or plain text (legacy).
# A value starting with $2b$ is treated as bcrypt.
DASHBOARD_PASSWORD=change-me-now
# Secret key used to sign session cookies — use a long random value.
DASHBOARD_SESSION_SECRET=replace-with-a-random-secret
# Set to '1' when served behind an HTTPS reverse proxy (enables Secure cookie flag).
DASHBOARD_HTTPS_ONLY=0

# --- Logging ---
LOG_LEVEL=INFO
# Set to 'json' for structured logging in production (default: console).
LOG_FORMAT=console

# --- Storage paths ---
ORCH_DB_PATH=/data/security_scans.db
REPORTS_DIR=/data/reports
WORKSPACE_DIR=/data/workspaces
TRIVY_CACHE_DIR=/data/cache/trivy

# --- OWASP ZAP ---
# Override the default API key for production deployments.
# ZAP_API_KEY=zap-api-key
# ZAP_API_URL=http://zap:8090

# --- CORS (optional) ---
# Comma-separated list of allowed origins. Leave empty for same-origin only.
# DASHBOARD_CORS_ORIGINS=https://example.com,https://app.example.com

# --- Email notifications ---
SMTP_SERVER=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=security@example.com
EMAIL_FROM_NAME=Security Scanner

# --- PostgreSQL (optional, default: SQLite) ---
# Uncomment and configure to use PostgreSQL instead of SQLite.
# DATABASE_URL=postgresql://security:change-me-postgres@postgres:5432/security_scans
# POSTGRES_DB=security_scans
# POSTGRES_USER=security
# POSTGRES_PASSWORD=change-me-postgres

# --- Tuning (optional) ---
# ANALYTICS_CACHE_TTL_SECONDS=60
# WEBHOOK_TIMEOUT_SECONDS=10
# WEBHOOK_RETRY_COUNT=3
# WEBHOOK_CIRCUIT_BREAKER_THRESHOLD=5
# DASHBOARD_MAX_SCAN_WORKERS=4
# DASHBOARD_MAX_SCAN_QUEUE=20
# DASHBOARD_SESSION_MAX_AGE=86400
# SCAN_TIMEOUT_SECONDS=3600
# SCAN_WATCHDOG_INTERVAL_SECONDS=120
