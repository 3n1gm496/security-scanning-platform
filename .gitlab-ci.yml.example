# ============================================================
# Security Scanning Platform — GitLab CI snippet per altri repository
# ============================================================
#
# NOTA: Questo file è un esempio minimale mantenuto per retrocompatibilità.
# Per l'integrazione completa si raccomanda di usare il template ufficiale:
#
#   include:
#     - project: 'security/security-scanning-platform'
#       ref: main
#       file: '/templates/gitlab-scan-template.yml'
#
# Documentazione completa: docs/gitlab-integration.md
# ============================================================

security_scan:
  stage: test
  image: alpine:3.19

  before_script:
    - apk add --no-cache curl jq --quiet

  script:
    - |
      set -euo pipefail

      if [ -z "${SECURITY_SCANNER_URL:-}" ] || [ -z "${SECURITY_SCANNER_API_KEY:-}" ]; then
        echo "[WARN] SECURITY_SCANNER_URL or SECURITY_SCANNER_API_KEY not configured. Skipping."
        echo '{"status":"skipped","reason":"missing_variables"}' > scan-results.json
        exit 0
      fi

      echo "[INFO] Running security scan for ${CI_PROJECT_NAME}..."

      SCAN_RESPONSE=$(curl \
        --fail-with-body --silent --show-error --max-time 300 \
        -X POST "${SECURITY_SCANNER_URL}/api/scan/trigger" \
        -H "Authorization: Bearer ${SECURITY_SCANNER_API_KEY}" \
        -H "Content-Type: application/x-www-form-urlencoded" \
        -d "target_type=git" \
        -d "target=${CI_PROJECT_URL}" \
        -d "name=${CI_PROJECT_NAME}" \
        -d "async_mode=false")

      echo "${SCAN_RESPONSE}" > scan-results.json
      echo "${SCAN_RESPONSE}" | jq .

      SCAN_STATUS=$(echo "${SCAN_RESPONSE}" | jq -r '.status // "unknown"')
      POLICY_STATUS=$(echo "${SCAN_RESPONSE}" | jq -r '.output.results[0].policy_status // "UNKNOWN"')
      FINDINGS_COUNT=$(echo "${SCAN_RESPONSE}" | jq -r '.output.results[0].findings_count // 0')

      echo "[INFO] Scan status:    ${SCAN_STATUS}"
      echo "[INFO] Policy status:  ${POLICY_STATUS}"
      echo "[INFO] Findings count: ${FINDINGS_COUNT}"

      if [ "${POLICY_STATUS}" = "BLOCK" ]; then
        echo "[ERROR] Security scan BLOCKED: critical findings detected (${FINDINGS_COUNT} total)"
        exit 1
      elif [ "${FINDINGS_COUNT}" -gt 0 ]; then
        echo "[WARN] Security scan passed with warnings (${FINDINGS_COUNT} findings)"
      else
        echo "[OK] Security scan passed: no findings"
      fi

  rules:
    - if: '$CI_PIPELINE_SOURCE == "merge_request_event"'
    - if: '$CI_COMMIT_BRANCH == $CI_DEFAULT_BRANCH'
    - if: '$CI_PIPELINE_SOURCE == "schedule"'

  allow_failure: false

  artifacts:
    when: always
    paths:
      - scan-results.json
    expire_in: 30 days
