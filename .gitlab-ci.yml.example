security_scan:
  stage: test
  image: alpine:latest
  
  before_script:
    - apk add --no-cache curl jq
  
  script:
    - echo "Running security scan for ${CI_PROJECT_NAME}..."
    
    # Trigger scan via API
    - |
      SCAN_RESPONSE=$(curl -X POST "${SECURITY_SCANNER_URL}/api/scan/trigger" \
        -H "Authorization: Bearer ${SECURITY_SCANNER_API_KEY}" \
        -H "Content-Type: application/x-www-form-urlencoded" \
        -d "target_type=git" \
        -d "target=${CI_PROJECT_URL}" \
        -d "name=${CI_PROJECT_NAME}" \
        -d "async_mode=false")
    
    - echo "Scan Response: ${SCAN_RESPONSE}"    
    
    # Parse results
    - SCAN_STATUS=$(echo "${SCAN_RESPONSE}" | jq -r '.status // "unknown"')
    - POLICY_STATUS=$(echo "${SCAN_RESPONSE}" | jq -r '.output.results[0].policy_status // "UNKNOWN"')
    - FINDINGS_COUNT=$(echo "${SCAN_RESPONSE}" | jq -r '.output.results[0].findings_count // 0')
    
    - echo "Scan Status=${SCAN_STATUS}"
    - echo "Policy Status=${POLICY_STATUS}"
    - echo "Findings Count=${FINDINGS_COUNT}"
    
    # Generate summary
    - |
      if [ "${POLICY_STATUS}" == "BLOCK" ]; then
        echo "❌ Security scan FAILED: Critical findings detected (${FINDINGS_COUNT} total)"
        exit 1
      elif [ "${FINDINGS_COUNT}" -gt 0 ]; then
        echo "⚠️  Security scan PASSED with warnings (${FINDINGS_COUNT} findings)"
      else
        echo "✅ Security scan PASSED: No findings"
      fi
  
  rules:
    - if: '$CI_PIPELINE_SOURCE == "merge_request_event"'
    - if: '$CI_COMMIT_BRANCH == "main" || $CI_COMMIT_BRANCH == "develop"'
    - if: '$CI_PIPELINE_SOURCE == "schedule"'
  
  allow_failure: false
  
  artifacts:
    when: always
    reports:
      junit: scan-results.xml
    paths:
      - scan-results.json
    expire_in: 30 days
